# Copy to .env and fill in before: docker compose up -d --build

# Public site URL for CORS (no trailing slash)
PUBLIC_URL=http://localhost

# Website port on the host (default 80)
WEB_PORT=80

# Leave empty when using nginx /api proxy (recommended for production)
REACT_APP_API_URL=

# GitHub Models (RAG + chatbot) — PAT with models scope
OpenAI__ApiKey=your_github_pat_here
OpenAI__Endpoint=https://models.github.ai/inference
OpenAI__ModelId=openai/gpt-4.1-mini
OpenAI__EmbeddingModelId=openai/text-embedding-3-small

QDRANT_COLLECTION_NAME=portfolio-collection

# Gmail SMTP (contact form)
Email__Provider=Smtp
Email__ToAddress=yashwanthanantha99@gmail.com
Email__Smtp__Host=smtp.gmail.com
Email__Smtp__Port=587
Email__Smtp__Username=yashwanthanantha99@gmail.com
Email__Smtp__Password=your_gmail_app_password
Email__Smtp__FromAddress=yashwanthanantha99@gmail.com
Email__Smtp__FromName=Portfolio Contact
